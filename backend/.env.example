# TIP Generator Environment Configuration
# Copy this file to .env and fill in the actual values

# Application
APP_NAME=TIP Generator
APP_VERSION=0.1.0
ENVIRONMENT=production
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost/tip_generator
DB_HOST=10.92.3.21
DB_PORT=5432
DB_NAME=tip_generator
DB_USER=tip_user
DB_PASSWORD=YOUR_PASSWORD_HERE

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# Authentik OAuth (to be configured)
AUTHENTIK_DOMAIN=auth.cloudigan.net
AUTHENTIK_CLIENT_ID=YOUR_CLIENT_ID
AUTHENTIK_CLIENT_SECRET=YOUR_CLIENT_SECRET
OAUTH_REDIRECT_URI=https://tip.cloudigan.net/auth/callback

# Security
SECRET_KEY=YOUR_SECRET_KEY_HERE_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# CORS
CORS_ORIGINS=https://tip.cloudigan.net,https://blue-tip.cloudigan.net,https://green-tip.cloudigan.net

# File Upload
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.xlsx,.xls,.pdf,.docx

# Task Queue (Redis + Celery)
REDIS_URL=redis://:password@10.92.3.93:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/tip-generator/app.log
