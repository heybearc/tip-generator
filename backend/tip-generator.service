[Unit]
Description=TIP Generator API
After=network.target postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/tip-generator/backend
Environment="PATH=/opt/tip-generator/backend/venv/bin"
ExecStart=/opt/tip-generator/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 4 --timeout-keep-alive 600
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
